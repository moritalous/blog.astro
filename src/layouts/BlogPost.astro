---
import Layout from './Layout.astro';
import Article from '../components/Article';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
}

const { title, description, pubDate, updatedDate } = Astro.props;
---

<Layout title={title} description={description}>
	<Article title={title} pubDate={pubDate.toISOString()} updatedDate={updatedDate?.toISOString()}>
		<slot />
	</Article>
</Layout>
