---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ページが見つかりません" description="お探しのページは見つかりませんでした">
	<main class="mx-auto max-w-3xl px-4 py-24 text-center">
		<p class="text-6xl font-bold text-gray-900">404</p>
		<p class="mt-4 text-gray-600">お探しのページは見つかりませんでした。</p>
		<a href="/" class="mt-8 inline-block text-gray-900 underline hover:text-gray-600">
			トップページへ戻る
		</a>
	</main>
</Layout>
